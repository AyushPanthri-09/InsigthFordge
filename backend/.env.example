# InsightForge AI Backend Configurations

# Server Host & Port
HOST=127.0.0.1
PORT=8000
DEBUG=True

# Database Configuration
DATABASE_URL=sqlite:///./insightforge.db

# API Credentials
GEMINI_API_KEY=your_gemini_api_key_here

# Constraints
# Maximum file upload size in bytes (10MB default)
MAX_UPLOAD_SIZE=10485760
