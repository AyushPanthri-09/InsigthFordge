# Railway injects PORT automatically. Do not set PORT manually for the public web service.

# Backend
DEBUG=false
HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=3000
MAX_UPLOAD_SIZE=10485760

# Required in production. Generate a strong value, for example:
# openssl rand -hex 32
SECRET_KEY=change-me-generate-a-strong-production-secret

# Optional. Leave unset to use SQLite inside the container filesystem.
# For durable production data, attach Railway Postgres and use its DATABASE_URL.
# DATABASE_URL=postgresql://user:password@host:port/database

# Frontend API URL.
# Leave blank for the single-container Railway deployment; the reverse proxy serves API routes
# from the same origin. Set this only if deploying the backend as a separate service.
VITE_INSIGHTFORGE_API_URL=
